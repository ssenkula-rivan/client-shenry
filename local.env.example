# ClientAgent Environment Configuration Example
# Copy this file to '.env' and fill in your actual credentials.
# Do not commit your actual '.env' file with real keys to Git.

# Server Port
PORT=5000

# ─── CORE AI KEY ───
# Get this from Console Anthropic (https://console.anthropic.com/)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── CLOUD DATABASE CONFIG (SUPABASE) ───
# Optional: Set these to migrate database storage to Supabase.
# If left blank, the app will run on a local SQLite file (database.db) automatically.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ─── EMAIL INTEGRATIONS (Configure ONE of the following for outreach) ───

# Option A: SendGrid Integration
SENDGRID_API_KEY=

# Option B: Standard SMTP Mail Server (e.g. Gmail App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password

# ─── SENDER INFORMATION ───
# Must match your authenticated sender address on SendGrid/Gmail.
EMAIL_SENDER=henry@brandcraft.ug
EMAIL_SENDER_NAME=Henry | BrandCraft

# ─── AUTOMATION TOGGLE ───
# Set to 'true' to automatically email leads scoring >= 75 as soon as they are qualifed.
AUTO_SEND=false
